# 服务端口
PORT=3001

# 环境
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=password
DB_NAME=law_case_management

# JWT配置
JWT_SECRET=law_firm_case_management_secret_key_2024
JWT_EXPIRES_IN=7d

# 文件上传配置
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=104857600

# 邮件配置 (可选)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=notification@example.com
SMTP_PASS=your_password
SMTP_FROM=律师事务所管理系统 <notification@example.com>

# 短信配置 (可选，预留)
SMS_API_KEY=
SMS_API_SECRET=
